{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ESnip",
  "version": "0.1.9",
  "identifier": "com.esnip.desktop",
  "build": {
    "beforeDevCommand": "pnpm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "简摘",
        "decorations": false,
        "visible": false,
        "width": 768,
        "height": 1080
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDFGREJERjNEODNENTFBOTEKUldTUkd0V0RQZC9iSDdwMVFKSE5WcllQeHZ0Sm5sSEFWejErZnpzdkY2bVhYekxBelduU3kxZHgK",
      "endpoints": [
        "https://github.com/pingo8888/ESnip/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
